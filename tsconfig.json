{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "paths": {
      "@prisma/client": ["./generated/prisma"]
    }
  },
  "include": ["src/**/*", "prisma.config.ts", "generated/**/*"]
}